# Basic auth for the dashboard. Change these BEFORE first start.
PANEL_USER=admin
PANEL_PASSWORD=please-change-me

# Where this panel can reach Ollama (project 05). Leave default if both run on the Pi.
OLLAMA_URL=http://host.docker.internal:11434

# Where this panel can reach the free-LLM-API router (project 07).
ROUTER_URL=http://host.docker.internal:8088
