{
    email admin@example.com
}

{$SITE_DOMAIN} {
    encode zstd gzip
    reverse_proxy app:8000

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "SAMEORIGIN"
        -Server
    }

    log {
        output stdout
        format console
    }
}
