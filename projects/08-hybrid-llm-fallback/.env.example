# Where to reach Ollama (project 05). Inside another container, use the service name
# (e.g. http://ollama:11434) on a shared network; from host networking, localhost works.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma3:1b

# Where to reach the free-LLM-API router (project 07).
ROUTER_URL=http://host.docker.internal:8088

# Timeouts (seconds).
OLLAMA_TIMEOUT=30
ROUTER_TIMEOUT=30
