# All keys are optional. The router skips any provider without a key.
# Get them at:
#   Groq:        https://console.groq.com/keys
#   Gemini:      https://aistudio.google.com/apikey
#   OpenRouter:  https://openrouter.ai/keys
#   Cerebras:    https://cloud.cerebras.ai
#   HuggingFace: https://huggingface.co/settings/tokens
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
HF_API_KEY=

# Comma-separated, fastest first. Providers without a key are skipped.
PROVIDER_ORDER=groq,cerebras,gemini,openrouter,huggingface

# Per-provider request timeout (seconds).
REQUEST_TIMEOUT=30
