# restic destination. Pick ONE.
#   local:    RESTIC_REPOSITORY=/mnt/backup-drive/restic
#   B2:       RESTIC_REPOSITORY=b2:your-bucket-name:pi5
#   S3-like:  RESTIC_REPOSITORY=s3:s3.amazonaws.com/your-bucket/pi5
RESTIC_REPOSITORY=/mnt/backup-drive/restic

# Long random string — encrypts every backup. LOSE THIS = LOSE BACKUPS.
# Generate one with:   openssl rand -base64 32
RESTIC_PASSWORD=

# Backblaze B2 credentials (only needed if using b2: above).
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# AWS / R2 / Wasabi creds (only needed for s3:).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Extra paths to back up (space-separated, optional).
# Example: EXTRA_PATHS="/home/pi/sites /home/pi/notes"
EXTRA_PATHS=
